generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Submission {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  name           String
  email          String?
  relation       String
  photoUrl       String?
  message        String
  firstMemory    String
  idealRelation  String
  videoVibe      String
}
